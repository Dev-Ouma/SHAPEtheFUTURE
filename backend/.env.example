# Backend local env — copy to .env (never commit real secrets)
PORT=3001
NODE_ENV=development
TYPEORM_SYNCHRONIZE=true

DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=shape_user
DB_PASSWORD=shape_pass
DB_NAME=shape_db

JWT_SECRET=local-dev-only-change-me-32chars-min
CORS_ORIGINS=http://localhost:3000

# Optional Redis (falls back to memory)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Seed (do not commit real values)
# SEED_ADMIN_EMAIL=admin@ouk.ac.ke
# SEED_ADMIN_PASSWORD=
