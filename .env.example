# Copy to .env and replace placeholder values before docker compose up.
# Never commit real secrets. See docs/deploy-hygiene.md.
#
# Production (bake FE public env inside Docker):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml build
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#   → JWT_SECRET and POSTGRES_PASSWORD are REQUIRED (compose fails if missing).
#   → Do NOT use docker-compose.dev.yml on a public host.
# Local convenience (weak defaults only):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
# Low-memory host (prebuilt .next from a workstation):
#   (cd frontend && NEXT_PUBLIC_*=… npm run build) then docker compose up -d --build
# Pre-flight:
#   node scripts/check-deploy-hygiene.mjs

NODE_ENV=production
TYPEORM_SYNCHRONIZE=false

# Reject undeclared DTO fields (recommended in production). Set false only to debug.
FORBID_NON_WHITELISTED=true

# Opt-in TypeORM migrations on backend boot (skipped when TYPEORM_SYNCHRONIZE=true).
# Keep false for dump-restored DBs until migration history is reconciled.
# Set true for greenfield / migration-managed production databases.
RUN_MIGRATIONS_ON_START=false

POSTGRES_USER=shape_user
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=shape_db

# Use a long random string (32+ chars). Required for production compose.
JWT_SECRET=change-me-long-random-jwt-secret

# Local seed only — set in your shell or private .env (never commit real values)
# SEED_ADMIN_EMAIL=admin@ouk.ac.ke
# SEED_ADMIN_PASSWORD=

# Cache: compose sets REDIS_HOST/REDIS_PORT. Optional full URL overrides both.
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# Admin HttpOnly cookie Secure flag.
# - HTTPS production: leave unset (defaults to secure when NODE_ENV=production)
# - HTTP-only staging / IP preview: AUTH_COOKIE_SECURE=false
# - Local docker-compose.dev.yml already forces false
# AUTH_COOKIE_SECURE=true

# Optional: comma-separated Safaricom callback source IPs
MPESA_CALLBACK_IPS=

# Production CORS allowlist for SHAPE portal.
# Local npm/dev uses open CORS. Add staging/HTTP origins here when needed.
CORS_ORIGINS=https://shape.ouk.ac.ke

# Browser admin traffic should use same-origin /api (Next rewrite).
# Admin SPA auth is HttpOnly cookie only (ouk_admin_token). Do not store JWTs in localStorage.
# NEXT_PUBLIC_* are baked into the client at build time:
#   - docker-compose.prod.yml → build args on the `runner` target
#   - prebuilt path → set them before `npm run build` on the workstation
NEXT_PUBLIC_API_URL=https://shape.ouk.ac.ke/api
NEXT_PUBLIC_SOCKET_URL=https://shape.ouk.ac.ke
NEXT_PUBLIC_SITE_URL=https://shape.ouk.ac.ke

# Student portal (SOMAS). Production builds redirect unauthenticated /portal*
# here unless demo mode is explicitly enabled.
# NEXT_PUBLIC_STUDENT_PORTAL_URL=https://my.ouk.ac.ke
# Local/dev: demo login stays on by default (NODE_ENV !== production).
# Production preview of in-app portal only:
# NEXT_PUBLIC_PORTAL_DEMO=true
# Force-disable demo even in development:
# NEXT_PUBLIC_PORTAL_DEMO=false

# Optional GA4 measurement ID. Loaded only after analytics cookie consent.
# Keep CSP Report-Only until gtag domains are allowlisted (see docs/edge-hardening.md).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Edge TLS (production only — never required for local).
# Local/dev keeps docker-compose.yml + docker-compose.dev.yml + nginx.conf (HTTP :80).
# HTTPS cutover (server):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.tls.yml up -d
# SSL_CERTS_DIR=/etc/letsencrypt
# ACME_WEBROOT=./certbot/www
# See docs/edge-hardening.md § TLS cutover. Enable HSTS only after HTTPS is stable.
